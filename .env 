# FoodTrace GH environment template
# Copy this file to .env and fill in real values before running locally.
#
# Production notes:
# - DATABASE_URL may be a JDBC URL or a hosted postgres:// URL (auto-converted).
# - JWT_SECRET must be set to a long random value in production.
# - PORT is provided by Railway at runtime; the default below is used for local dev.

# ── Core ─────────────────────────────────────────────────────────────────────

# PostgreSQL connection string.
# Local Spring example:   jdbc:postgresql://localhost:5432/foodtrace
# Railway / hosted:       postgres://user:pass@host:5432/dbname  (auto-converted)
DATABASE_URL=postgresql://neondb_owner:npg_vEku15hoyPVr@ep-bold-river-aq26j7cy-pooler.c-8.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# JWT signing secret. Must be at least 32 random characters in production.
JWT_SECRET=replace-with-a-random-32-character-secret

# Backend server port. Railway sets this automatically.
PORT=3000

# Allowed browser origins for CORS (comma-separated).
FRONTEND_URL=http://localhost:5173,http://127.0.0.1:5173

# Allowed mobile deep-link or Expo origins (comma-separated).
MOBILE_ORIGINS=exp://localhost:8081,myapp://

# Public base URLs used in QR code image generation.
# After a Railway deploy, set these to your real URLs:
#   PUBLIC_API_URL=https://your-foodtrace-backend.up.railway.app
#   PUBLIC_WEB_URL=https://your-foodtrace-web.example.com
PUBLIC_API_URL=http://localhost:3000
PUBLIC_WEB_URL=http://localhost:5173

# Local directory where QR image PNGs are stored (served at /uploads/**).
UPLOADS_DIR=uploads

# Demo/debug only: set true to return the OTP in the /auth/request-otp response.
# Never enable in production.
EXPOSE_OTP=false

# ── Africa's Talking — SMS & USSD ────────────────────────────────────────────
# Required for: OTP delivery by SMS, USSD menu callbacks.
# Obtain credentials at https://africastalking.com after creating an app.
# Leave blank to disable SMS/USSD — the endpoints still accept requests but
# will not send messages.
#
# AFRICASTALKING_API_KEY   → your app's live API key (use "sandbox" key for testing)
# AFRICASTALKING_USERNAME  → your Africa's Talking account username
# AFRICASTALKING_SHORTCODE → your registered short code or alphanumeric sender ID
AFRICASTALKING_API_KEY=
AFRICASTALKING_USERNAME=sandbox
AFRICASTALKING_SHORTCODE=

# ── Google Cloud Text-to-Speech ───────────────────────────────────────────────
# Required for: audio summaries of scan results (/api/audio/speech).
# Steps:
#   1. Create a GCP project and enable the Cloud Text-to-Speech API.
#   2. Create a service account, download its JSON key file.
#   3. Set GOOGLE_APPLICATION_CREDENTIALS to the absolute path of that file.
#   4. Set GOOGLE_CLOUD_PROJECT to your GCP project ID.
# The Google SDK reads GOOGLE_APPLICATION_CREDENTIALS automatically.
# Leave blank to disable TTS — the /api/audio/speech endpoint returns
# {"status": "not_configured"} without error.
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_CLOUD_PROJECT=

# ── AWS S3-compatible storage ─────────────────────────────────────────────────
# Required for: persisting QR code images to object storage.
# Without these, generated QR PNGs are saved to UPLOADS_DIR on the local
# filesystem and served via /uploads/**. That is fine for development and
# single-instance deploys; use S3 for multi-instance / Railway volume-less setups.
# The AWS SDK picks up AWS_ACCESS_KEY_ID and AWS_SECRET_ACCESS_KEY automatically.
#
# AWS_ACCESS_KEY_ID     → IAM access key
# AWS_SECRET_ACCESS_KEY → IAM secret key
# AWS_REGION            → bucket region (e.g. eu-west-1)
# AWS_BUCKET_NAME       → name of the S3 or R2 bucket
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-west-1
AWS_BUCKET_NAME=foodtrace-gh-prod

# ── Frontend feature flags ────────────────────────────────────────────────────

# Show demo shortcuts (pre-seeded accounts, QR code buttons) in the web UI.
# Keep false for real pilot and production builds.
VITE_SHOW_DEMO_MODE=false

# Enable the medicine/pharmacy module in the web UI.
# Keep false for the first food-traceability pilot.
VITE_ENABLE_DRUG_MODULE=false

# Override the API base URL used by the web app.
# Leave blank to auto-detect (same origin in production, localhost:3000 in dev).
# VITE_API_BASE_URL=https://your-foodtrace-backend.up.railway.app/api
