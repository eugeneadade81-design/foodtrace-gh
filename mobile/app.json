{
  "expo": {
    "name": "FoodTrace GH",
    "slug": "foodtrace-gh",
    "version": "0.1.0",
    "orientation": "portrait",
    "platforms": [
      "ios",
      "android"
    ],
    "updates": {
      "fallbackToCacheTimeout": 0
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Allow FoodTrace GH to use your camera to scan product QR codes."
        }
      ],
      "expo-barcode-scanner"
    ]
  }
}
