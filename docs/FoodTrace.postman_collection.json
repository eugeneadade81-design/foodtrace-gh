{
  "info": {
    "_postman_id": "7d0ce840-7c93-4f20-b4d0-1fd3a6d51d11",
    "name": "FoodTrace GH API",
    "description": "FoodTrace GH API examples for auth, traceability, reporting, and regulator workflows.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register Consumer",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Ama Mensah\",\n  \"phone\": \"+233201111111\",\n  \"email\": \"ama@example.com\",\n  \"password\": \"Password123!\",\n  \"role\": \"consumer\",\n  \"language\": \"en\"\n}"
            }
          }
        },
        {
          "name": "Request OTP",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/request-otp",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"identifier\": \"+233201111111\",\n  \"purpose\": \"login\"\n}"
            }
          }
        },
        {
          "name": "Verify OTP",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/verify-otp",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"identifier\": \"+233201111111\",\n  \"token\": \"123456\",\n  \"purpose\": \"login\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"identifier\": \"+233201111111\",\n  \"password\": \"Password123!\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Farmer",
      "item": [
        {
          "name": "Create Farm",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/food/farms",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Agyemang Farm\",\n  \"district\": \"Ejisu\",\n  \"region\": \"Ashanti\",\n  \"cropTypes\": [\"tomato\", \"maize\"]\n}"
            }
          }
        },
        {
          "name": "Log Input",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/food/input-logs",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"cropCycleId\": \"{{cropCycleId}}\",\n  \"inputType\": \"pesticide\",\n  \"productName\": \"Pesticide X\",\n  \"applicationDate\": \"2026-04-20\",\n  \"withdrawalPeriodDays\": 14,\n  \"epaApprovalStatus\": \"approved\"\n}"
            }
          }
        },
        {
          "name": "Get Market Ready Status",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/food/dashboard"
          }
        }
      ]
    },
    {
      "name": "Manufacturer",
      "item": [
        {
          "name": "Create Profile",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/manufacturer/profile",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"companyName\": \"FoodTrace Foods Ltd\",\n  \"fdaRegistrationNumber\": \"FDA-12345\",\n  \"sector\": \"food\",\n  \"subscriptionTier\": \"small\"\n}"
            }
          }
        },
        {
          "name": "Create Batch",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/manufacturer/batches",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"batchNumber\": \"FB-1001\",\n  \"ingredientSources\": [\"Agyemang Farm\"],\n  \"processingSteps\": [\"mix\", \"heat\", \"pack\"],\n  \"qualityChecks\": [\"visual pass\"],\n  \"packagingDate\": \"2026-05-01\",\n  \"expiryDate\": \"2027-05-01\"\n}"
            }
          }
        },
        {
          "name": "Self Recall",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/manufacturer/recalls",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"batchId\": \"{{batchId}}\",\n  \"recallType\": \"manufacturer\",\n  \"reason\": \"Possible contamination\",\n  \"scopeDistricts\": [\"Accra\", \"Kumasi\"]\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Consumer",
      "item": [
        {
          "name": "Scan Food",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/scan/FT-QR-1001"
          }
        },
        {
          "name": "Scan Drug",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/drug/scan/DR-QR-1001"
          }
        },
        {
          "name": "Submit Report",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/scan/FT-QR-1001/report",
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "description", "value": "The label is damaged and the product looks spoiled.", "type": "text" },
                { "key": "district", "value": "Accra", "type": "text" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Pharmacy",
      "item": [
        {
          "name": "Register Pharmacy",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/drug/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"businessName\": \"MediCare Pharmacy\",\n  \"ghanaPharmacyCouncilNumber\": \"GPC-1001\",\n  \"district\": \"Kumasi\",\n  \"region\": \"Ashanti\"\n}"
            }
          }
        },
        {
          "name": "Drug Batch Log",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/drug/batches",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"drugId\": \"{{drugId}}\",\n  \"batchNumber\": \"DB-1001\",\n  \"manufactureDate\": \"2026-05-01\",\n  \"expiryDate\": \"2027-05-01\",\n  \"quantityReceived\": 100,\n  \"quantityRemaining\": 95,\n  \"supplierName\": \"Global Med Supplies\"\n}"
            }
          }
        },
        {
          "name": "Get Drug QR",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/drug/dashboard"
          }
        }
      ]
    },
    {
      "name": "Regulator",
      "item": [
        {
          "name": "Dashboard Overview",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/regulator/dashboard"
          }
        },
        {
          "name": "Issue Recall",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/regulator/recalls",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"batchId\": \"{{batchId}}\",\n  \"reason\": \"Public safety issue\",\n  \"scopeDistricts\": [\"Accra\", \"Kumasi\"],\n  \"domain\": \"food\"\n}"
            }
          }
        },
        {
          "name": "Review Report",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/regulator/reports",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reportId\": \"{{reportId}}\",\n  \"status\": \"reviewing\"\n}"
            }
          }
        }
      ]
    }
  ],
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000/api" },
    { "key": "token", "value": "" },
    { "key": "batchId", "value": "" },
    { "key": "cropCycleId", "value": "" },
    { "key": "drugId", "value": "" },
    { "key": "reportId", "value": "" }
  ]
}

