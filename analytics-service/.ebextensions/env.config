# Elastic Beanstalk environment configuration for the analytics-service.
#
# ONLY non-secret, environment-independent values live here (committed to git).
# Endpoint-specific and secret values are set out-of-band so they never land in
# the repo — see DEPLOY.md:
#   eb setenv DB_URL=jdbc:postgresql://<rds-endpoint>:5432/foodtrace \
#             DB_USERNAME=<user> DB_PASSWORD=<secret> \
#             REDIS_HOST=<elasticache-endpoint> \
#             AT_USERNAME=<at-user> AT_API_KEY=<secret> AT_SENDER_ID=<id> \
#             S3_BUCKET=<bucket> CORS_ALLOWED_ORIGINS=https://<amplify-domain>
#
option_settings:
  aws:elasticbeanstalk:application:environment:
    # Use the PostgreSQL JDBC driver against RDS (H2 is local-only).
    DB_DRIVER: org.postgresql.Driver
    # Role 1 owns the RDS tables; do NOT re-run schema.sql/data.sql on restart.
    SQL_INIT_MODE: never
    # Turn on the real S3 + Africa's Talking integrations in the cloud.
    S3_ENABLED: "true"
    SMS_ENABLED: "true"
    AWS_REGION: eu-west-1
