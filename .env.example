# FoodTrace GH environment template
# Copy this file to .env and replace the placeholder values before running locally.

# PostgreSQL connection string.
# Local example: postgresql://postgres:postgres123@localhost:5432/foodtrace_gh
DATABASE_URL=postgresql://postgres:postgres123@localhost:5432/foodtrace_gh

# Redis cache connection. Leave blank only if you want the backend to run without cache.
REDIS_URL=redis://localhost:6379

# JWT signing secret for access tokens. Use at least 32 random characters in production.
JWT_SECRET=replace-with-a-random-32-character-secret

# Backend server port and environment.
PORT=3000
NODE_ENV=development

# Allowed browser origins for CORS. Include both localhost and 127.0.0.1 during local demos.
FRONTEND_URL=http://localhost:5173,http://127.0.0.1:5173

# Allowed mobile deep-link or Expo origins.
MOBILE_ORIGINS=exp://localhost:8081,myapp://

# Africa's Talking SMS/USSD credentials.
# Get these from https://africastalking.com after creating an app.
AFRICASTALKING_API_KEY=
AFRICASTALKING_USERNAME=sandbox
AFRICASTALKING_SHORTCODE=

# Google Cloud Text-to-Speech.
# GOOGLE_APPLICATION_CREDENTIALS should point to a local service-account JSON file.
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_CLOUD_PROJECT=

# Optional S3-compatible QR/image storage.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-west-1
AWS_BUCKET_NAME=foodtrace-gh-prod

# Optional public base URLs used in QR generation and callbacks.
PUBLIC_WEB_URL=http://localhost:5173
PUBLIC_API_URL=http://localhost:3000
